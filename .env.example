# =============================================================================
# VaakSeva — Environment Configuration
#
# Architecture A (Production — fully self-hosted, zero commercial API deps):
#   LLM:       Sarvam-30B via SGLang (self-hosted, L40S/A10 GPU)
#   STT:       faster-whisper large-v2-hindi (self-hosted, GPU)
#   TTS:       maya-research/Veena 3B NF4 (self-hosted, GPU)
#   Embed:     Qwen/Qwen3-Embedding-8B (self-hosted, GPU or CPU)
#   Rerank:    Qwen/Qwen3-Reranker-8B (self-hosted, GPU or CPU)
#
# Architecture B (Dev/Demo — API-first, no GPU required):
#   Override:  LLM_BACKEND=sarvam STT_BACKEND=sarvam TTS_BACKEND=sarvam
#   Requires:  SARVAM_API_KEY below
# =============================================================================

# =============================================================================
# API Keys
# =============================================================================

# Sarvam AI API key — used for STT (Saaras V3), LLM (Sarvam-30B), TTS (Bulbul v3)
# Get free access at: https://docs.sarvam.ai
# Used as dev/demo fallback when self-hosted backends are unavailable
SARVAM_API_KEY=

# Groq API key — Llama-3.3-70B at 250-500 tok/s
# Used as LLM speed fallback: LLM_BACKEND=groq
GROQ_API_KEY=

# =============================================================================
# LLM Configuration
# =============================================================================
# Options: sglang (production) | sarvam | groq | ollama | vllm
#
# sglang = Sarvam-30B Q4_K_M via self-hosted SGLang server (recommended)
#   Start: python -m sglang.launch_server --model-path /models/sarvam-30b-q4_k_m.gguf --port 8081
#   Why SGLang over vLLM: RadixAttention caches RAG prefixes (29% throughput gain)
#   Hardware: Vast.ai/RunPod A10 (24 GB, Q4_K_M = 19 GB) or L40S (48 GB, Q6_K = 26 GB)
#
# sarvam = Sarvam-30B via hosted API (free, good for dev — breaks self-hosted narrative)
LLM_BACKEND=sglang

# SGLang server URL (matches docker-compose sglang service)
SGLANG_BASE_URL=http://localhost:8081
SGLANG_MODEL=sarvam-30b

# Sarvam API LLM config (when LLM_BACKEND=sarvam)
SARVAM_LLM_MODEL=sarvam-30b

# Groq config (when LLM_BACKEND=groq)
GROQ_MODEL=llama-3.3-70b-versatile

# Self-hosted fallbacks
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=sarvam-m:latest
VLLM_BASE_URL=http://localhost:8001
VLLM_MODEL=sarvamai/sarvam-30b

# LLM generation params
# Sarvam-30B is a reasoning model: chain-of-thought consumes 500-800 tokens
# Set max_tokens high enough for reasoning + final answer
LLM_MAX_TOKENS=4096
LLM_TEMPERATURE=0.1
LLM_TOP_P=0.9
LLM_TIMEOUT_S=60

# =============================================================================
# Embeddings
# =============================================================================
# Options: qwen3 | e5
#
# qwen3 = Qwen/Qwen3-Embedding-8B (production, #1 MTEB Multilingual, 7168D)
#         Swap to Qwen3-Embedding-0.6B (1024D) for CPU dev: QWEN3_EMBED_MODEL=Qwen/Qwen3-Embedding-0.6B
# e5    = intfloat/multilingual-e5-large-instruct (legacy fallback, 1024D)
EMBEDDER_BACKEND=qwen3
QWEN3_EMBED_MODEL=Qwen/Qwen3-Embedding-8B
# For CPU dev (no GPU): QWEN3_EMBED_MODEL=Qwen/Qwen3-Embedding-0.6B
EMBED_DEVICE=auto

# =============================================================================
# Reranker
# =============================================================================
# Options: qwen3 | noop
#
# qwen3 = Qwen/Qwen3-Reranker-8B (#1 MTEB multilingual, GPU: 300-800ms for 20 candidates)
#         Swap to 0.6B for CPU dev: QWEN3_RERANKER_MODEL=Qwen/Qwen3-Reranker-0.6B
# noop  = passthrough (fastest, worst precision)
RERANKER_BACKEND=qwen3
QWEN3_RERANKER_MODEL=Qwen/Qwen3-Reranker-8B
# For CPU dev (no GPU): QWEN3_RERANKER_MODEL=Qwen/Qwen3-Reranker-0.6B
RERANKER_DEVICE=auto

# =============================================================================
# Speech-to-Text
# =============================================================================
# Options: whisper | sarvam
#
# whisper = collabora/faster-whisper-large-v2-hindi (self-hosted, production)
#   5.33% WER on Hindi FLEURS — best open-source Hindi STT
#   INT8 on GPU: ~0.5-1.5s for 10s clip; uses ~1.5 GB VRAM at INT8
#   Model weights download automatically via faster-whisper on first run
#   For best WER: set STT_MODEL=ai4bharat/IndicWhisper (requires HF token)
#
# sarvam = Sarvam Saaras V3 (hosted API, dev fallback, needs SARVAM_API_KEY)
STT_BACKEND=whisper
STT_MODEL=large-v3
STT_DEVICE=auto
STT_COMPUTE_TYPE=int8
STT_LANGUAGE=hi
STT_LANGUAGE_THRESHOLD=0.7

# Sarvam STT config (when STT_BACKEND=sarvam)
SARVAM_STT_MODEL=saaras:v3
SARVAM_STT_LANGUAGE=hi-IN

# =============================================================================
# Text-to-Speech
# =============================================================================
# Options: veena | sarvam | kokoro | edge
#
# veena  = maya-research/Veena 3B NF4 (self-hosted GPU, production — RECOMMENDED)
#   India's first open-source Hindi/English TTS, Apache 2.0
#   NF4 quantized: ~2 GB VRAM alongside Sarvam-30B on L40S
#   Voices: aditi (female), ravi (male), priya (female), arjun (male)
#   GPU first-chunk latency: ~2-4s streaming
#
# sarvam = Sarvam Bulbul v3 (hosted API, dev/demo fallback, needs SARVAM_API_KEY)
#   CER 0.0173, ~600ms, priya speaker, Rs 30/10K chars
#
# kokoro = Kokoro-82M (self-hosted, CPU-fast, Apache 2.0)
#   #1 on TTS Arena; real-time on CPU; Hindi voices hf_alpha / hf_omega
#   Use as fallback when no GPU available
TTS_BACKEND=veena
TTS_DEVICE=auto

# Veena voices: aditi, priya (female) | ravi, arjun (male)
VEENA_MODEL=maya-research/Veena
VEENA_VOICE=aditi

# Sarvam TTS (when TTS_BACKEND=sarvam)
SARVAM_TTS_MODEL=bulbul:v3
SARVAM_TTS_SPEAKER=priya

# Kokoro (when TTS_BACKEND=kokoro)
KOKORO_VOICE=hf_alpha

# Edge TTS (emergency fallback only)
EDGE_TTS_VOICE=hi-IN-MadhurNeural

# =============================================================================
# Weaviate (vector database, v1.32)
# =============================================================================
# Local dev: run via docker compose up weaviate -d
# Production: runs in same Docker Compose stack
WEAVIATE_HOST=localhost
WEAVIATE_PORT=7700
WEAVIATE_GRPC_PORT=50051
WEAVIATE_COLLECTION=GovernmentSchemes

# =============================================================================
# Redis (job queue)
# =============================================================================
REDIS_URL=redis://localhost:6379

# =============================================================================
# RAG pipeline
# =============================================================================
TOP_K_RETRIEVAL=20
TOP_K_RERANK=5
# 0.75 = mostly dense vector search; 0.0 = pure BM25; 1.0 = pure dense
HYBRID_ALPHA=0.75

# =============================================================================
# Latency budgets (milliseconds)
# =============================================================================
LATENCY_BUDGET_STT_MS=1000
LATENCY_BUDGET_EMBEDDING_MS=500
LATENCY_BUDGET_RETRIEVAL_MS=200
LATENCY_BUDGET_LLM_MS=3000
LATENCY_BUDGET_TTS_MS=1000
LATENCY_BUDGET_TOTAL_MS=6000

# =============================================================================
# Privacy and security
# =============================================================================
PHONE_HASH_SALT=change-this-to-a-random-secret

# =============================================================================
# Logging
# =============================================================================
LOG_LEVEL=INFO

# =============================================================================
# Deployment
# =============================================================================
# GCP project (used for Cloud Logging, monitoring)
GCP_PROJECT_ID=revsight-492123
GCP_REGION=asia-south1

# GPU pod model directory — bind-mount your downloaded models here
# Vast.ai/RunPod: set MODEL_DIR to the persistent volume path on your pod
MODEL_DIR=./models
