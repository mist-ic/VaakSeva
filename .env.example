# Backend
LLM_BACKEND=sarvam
# Options: sarvam | groq | ollama | vllm
# sarvam = Sarvam-30B via hosted API (free as of April 2026, recommended)
# groq   = Llama-3.3-70B via Groq LPU (250-500 tok/s, speed fallback)
# ollama = local Ollama (CPU, development only)
# vllm   = self-hosted vLLM server (GPU production deployment)

# Sarvam AI API key (used for STT, LLM, and TTS)
SARVAM_API_KEY=

# Groq API key (for LLM_BACKEND=groq)
GROQ_API_KEY=

# Sarvam API config
SARVAM_LLM_MODEL=sarvam-30b
GROQ_MODEL=llama-3.3-70b-versatile

# Self-hosted LLM config (only needed if using ollama or vllm backend)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=sarvam-m:latest
VLLM_BASE_URL=http://localhost:8000
VLLM_MODEL=sarvamai/sarvam-30b

# Embeddings
EMBEDDER_BACKEND=qwen3
# Options: qwen3 | e5
# qwen3 = Qwen/Qwen3-Embedding-0.6B (default, #1 MTEB Multilingual, fast on CPU)
# e5    = intfloat/multilingual-e5-large-instruct (legacy fallback)
QWEN3_EMBED_MODEL=Qwen/Qwen3-Embedding-0.6B
# For offline indexing with best quality, set: Qwen/Qwen3-Embedding-8B

# Reranker
RERANKER_BACKEND=qwen3
# Options: qwen3 | noop
# qwen3 = Qwen3-Reranker-0.6B (enabled by default, fast on CPU ~200-400ms)
# noop  = passthrough (no reranking)
QWEN3_RERANKER_MODEL=Qwen/Qwen3-Reranker-0.6B

# STT
STT_BACKEND=sarvam
# Options: sarvam | whisper
# sarvam  = Sarvam Saaras V3 API (#1 Hindi STT, beats GPT-4o on IndicVoices)
# whisper = faster-whisper large-v3 (self-hosted, best open-source Hindi STT)
SARVAM_STT_MODEL=saaras:v3
SARVAM_STT_LANGUAGE=hi-IN
STT_MODEL=large-v3
STT_DEVICE=cpu
STT_COMPUTE_TYPE=int8
STT_LANGUAGE_THRESHOLD=0.7

# TTS
TTS_BACKEND=sarvam
# Options: sarvam | kokoro | edge
# sarvam = Sarvam Bulbul v3 API (Rs 30/10K chars, ~600ms, best Hindi TTS as of 2026)
# kokoro = Kokoro-82M Hindi (self-hosted, Apache 2.0, #1 TTS Arena, fast on CPU)
# edge   = Microsoft Edge TTS (emergency fallback only, unofficial endpoint)
SARVAM_TTS_MODEL=bulbul:v3
SARVAM_TTS_SPEAKER=priya
KOKORO_VOICE=hf_alpha
EDGE_TTS_VOICE=hi-IN-MadhurNeural

# Weaviate (v1.32 -- see docker-compose.yml)
WEAVIATE_HOST=localhost
WEAVIATE_PORT=7700
WEAVIATE_GRPC_PORT=50051
WEAVIATE_COLLECTION=GovernmentSchemes

# Redis (job queue)
REDIS_URL=redis://localhost:6379

# RAG
TOP_K_RETRIEVAL=20
# Reduced from 50 (reranker is now enabled by default)
TOP_K_RERANK=5
HYBRID_ALPHA=0.75
# alpha=1.0 pure dense, alpha=0.0 pure BM25, 0.75 = mostly dense

# Latency budgets (milliseconds)
LATENCY_BUDGET_STT_MS=1000
LATENCY_BUDGET_EMBEDDING_MS=500
LATENCY_BUDGET_RETRIEVAL_MS=200
LATENCY_BUDGET_LLM_MS=3000
LATENCY_BUDGET_TTS_MS=1000
LATENCY_BUDGET_TOTAL_MS=6000

# Privacy
PHONE_HASH_SALT=change-this-to-a-random-secret

# Logging
LOG_LEVEL=INFO

# GCP (for Cloud Run deployment)
GCP_PROJECT_ID=revsight-492123
GCP_REGION=asia-south1
