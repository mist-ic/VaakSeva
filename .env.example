# Backend
LLM_BACKEND=ollama
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=sarvam-m:latest
VLLM_BASE_URL=http://localhost:8000
VLLM_MODEL=sarvamai/sarvam-30b

# Embeddings
EMBEDDER_BACKEND=e5
# Options: qwen3 | e5
# qwen3 = Qwen/Qwen3-Embedding-8B (requires GPU)
# e5    = intfloat/multilingual-e5-large-instruct (CPU friendly)

RERANKER_BACKEND=noop
# Options: qwen3 | noop
# qwen3 = Qwen/Qwen3-Reranker-8B (requires GPU)
# noop  = passthrough (no reranking, faster for dev)

# STT
STT_BACKEND=whisper
STT_MODEL=large-v2
STT_DEVICE=cpu
STT_COMPUTE_TYPE=int8
STT_LANGUAGE_THRESHOLD=0.7

# TTS
TTS_BACKEND=edge
# Options: veena | edge
# veena = maya-research/Veena (requires GPU, self-hosted)
# edge  = edge-tts (free, no GPU, no API key)

EDGE_TTS_VOICE=hi-IN-MadhurNeural

# Weaviate
WEAVIATE_HOST=localhost
WEAVIATE_PORT=8080
WEAVIATE_GRPC_PORT=50051
WEAVIATE_COLLECTION=GovernmentSchemes

# Redis (job queue)
REDIS_URL=redis://localhost:6379

# WhatsApp (Baileys -> FastAPI callback)
WHATSAPP_BACKEND_URL=http://localhost:8080
FASTAPI_PORT=8080

# Privacy
PHONE_HASH_SALT=change-this-to-a-random-secret

# Logging
LOG_LEVEL=INFO
LOG_DIR=./logs

# RAG
TOP_K_RETRIEVAL=50
TOP_K_RERANK=5
HYBRID_ALPHA=0.75
# alpha=1.0 pure dense, alpha=0.0 pure BM25, 0.75 = mostly dense

# Latency budgets (milliseconds)
LATENCY_BUDGET_STT_MS=1000
LATENCY_BUDGET_EMBEDDING_MS=500
LATENCY_BUDGET_RETRIEVAL_MS=200
LATENCY_BUDGET_LLM_MS=3000
LATENCY_BUDGET_TTS_MS=1000
LATENCY_BUDGET_TOTAL_MS=6000

# GCP (for Cloud Run / GCS)
GCP_PROJECT_ID=revsight-492123
GCP_REGION=asia-south1
